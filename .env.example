# Supabase — get these from https://supabase.com/dashboard → Project Settings → API
#
# Safe to expose to the browser (anon key has RLS enforcement).
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never prefix with NEXT_PUBLIC_. Used for admin operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — transactional email (referral invites, etc.)
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# App base URL — used to build invite links in emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mercado Pago — PIX payments and wallet deposits
# Get your credentials at https://www.mercadopago.com.br/developers/panel
# Use test credentials (APP_USR-...) for development, production credentials for live
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
# Webhook secret — set this in MP Dashboard → Webhooks → Secret key
# Leave empty in dev to skip signature validation
MERCADO_PAGO_WEBHOOK_SECRET=your_webhook_secret_here
